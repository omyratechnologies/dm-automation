{
  "name": "saas-dm-automations",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "prisma generate --schema packages/db/prisma/schema.prisma",
    "dev:web": "npm run dev --workspace @repo/web",
    "dev:api": "npm run start:dev --workspace @repo/api",
    "build": "npm run build --workspace @repo/shared && npm run build --workspace @repo/api && npm run build --workspace @repo/web",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:generate": "prisma generate --schema packages/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema packages/db/prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema packages/db/prisma/schema.prisma",
    "db:validate": "prisma validate --schema packages/db/prisma/schema.prisma"
  },
  "devDependencies": {
    "prisma": "^6.18.0"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.13",
    "@nestjs/throttler": "^6.5.0"
  }
}
