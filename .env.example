# ============================================================================
# saas-dm-automations — environment template
# Copy to .env (repo root) and fill in real values. NEVER commit real secrets.
# ============================================================================

# ---------------------------------------------------------------------------
# Docker Compose (postgres/redis containers)
# ---------------------------------------------------------------------------
POSTGRES_USER=postgres                                # Postgres superuser for the local container
POSTGRES_PASSWORD=postgres                            # Postgres password for the local container
POSTGRES_DB=dm_automation                             # Database name created on first boot

# ---------------------------------------------------------------------------
# Required — API (apps/api — NestJS, validated by apps/api/src/config/env.ts)
# ---------------------------------------------------------------------------
NODE_ENV=development                                  # development | test | production
PORT=4000                                             # API listen port
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dm_automation   # Postgres connection string (inside compose use host "postgres")
REDIS_URL=redis://localhost:6379                      # Redis for BullMQ queues + rate limiting (inside compose use host "redis")
CLERK_SECRET_KEY=sk_test_replace_me                   # Clerk backend secret key
TOKEN_MASTER_KEY=replace_with_32_byte_base64_key      # openssl rand -base64 32

# ---------------------------------------------------------------------------
# Optional — API
# ---------------------------------------------------------------------------
CLERK_PUBLISHABLE_KEY=                                # Clerk publishable key (optional server-side)
OPENROUTER_API_KEY=                                   # OpenRouter API key (primary, preferred over OPENAI_API_KEY)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1      # OpenRouter base URL
AI_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free                                   # Model to use (OpenRouter model ID, e.g. openai/gpt-4o-mini, ~openai/gpt-latest)
OPENAI_API_KEY=                                       # OpenAI API key (fallback if OpenRouter not configured)
INSTAGRAM_APP_ID=                                     # Meta app ID (Instagram product)
INSTAGRAM_APP_SECRET=                                 # Meta app secret — used for X-Hub-Signature-256 verification
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=                       # Self-chosen token echoed back during Meta webhook verification
INSTAGRAM_GRAPH_URL=https://graph.instagram.com/v25.0 # Instagram Graph API base URL
INSTAGRAM_OAUTH_REDIRECT_URI=http://localhost:3000/callback/instagram  # OAuth redirect registered in the Meta dashboard
STRIPE_SECRET_KEY=                                    # Stripe secret key
STRIPE_WEBHOOK_SECRET=                                # Stripe webhook signing secret
STRIPE_PRICE_PRO=                                     # Stripe price ID for the PRO plan
WEB_ORIGIN=http://localhost:3000                      # Allowed CORS origin(s), comma-separated

# ---------------------------------------------------------------------------
# Web (apps/web — Next.js, required at build time)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000             # Base URL the browser uses to reach the NestJS API
NEXT_PUBLIC_HOST_URL=http://localhost:3000            # Public URL of the web app
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=                   # Clerk publishable key (browser)
NEXT_PUBLIC_INSTAGRAM_APP_ID=                        # App ID exposed to the browser for the OAuth dialog
NEXT_PUBLIC_INSTAGRAM_EMBEDDED_OAUTH_URL=            # Browser-side OAuth dialog URL. MUST be Instagram Business Login: https://www.instagram.com/oauth/authorize?client_id=...&redirect_uri=...&response_type=code&scope=instagram_business_basic,instagram_business_manage_messages,instagram_business_manage_comments (NOT facebook.com/dialog/oauth — that rejects Instagram app IDs)

# ---------------------------------------------------------------------------
# Web — server-side only (apps/web — Next.js server actions)
# ---------------------------------------------------------------------------
INSTAGRAM_BASE_URL=https://graph.instagram.com        # Instagram Graph base URL used by web server actions
INSTAGRAM_TOKEN_URL=                                  # OAuth token exchange endpoint (https://graph.facebook.com/v21.0/oauth/access_token)
INSTAGRAM_CLIENT_ID=                                  # Same as INSTAGRAM_APP_ID (web-side naming)
INSTAGRAM_CLIENT_SECRET=                              # Same as INSTAGRAM_APP_SECRET (web-side naming)
INSTAGRAM_EMBEDDED_OAUTH_URL=                         # Server-side OAuth dialog URL (same Instagram Business Login URL as NEXT_PUBLIC_INSTAGRAM_EMBEDDED_OAUTH_URL)
UPSTASH_REDIS_REST_URL=                               # Upstash Redis REST URL (web rate limiting, optional)
UPSTASH_REDIS_REST_TOKEN=                             # Upstash Redis REST token (optional)
